

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/course_content
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=86400000

# Storage Strategy: "local" or "s3"
STORAGE_STRATEGY=local

# AWS S3 Configuration (only required when STORAGE_STRATEGY=s3)
AWS_S3_BUCKET_NAME=your-bucket-name
AWS_S3_REGION=us-east-1
AWS_S3_ACCESS_KEY=your_aws_access_key
AWS_S3_SECRET_KEY=your_aws_secret_key

# CORS Allowed Origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Server Port
SERVER_PORT=8080
